<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rhythm Game</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="game-container">
        <div class="lane" data-key="c"></div>
        <div class="lane" data-key="v"></div>
        <div class="lane" data-key="n"></div>
        <div class="lane" data-key="m"></div>
    </div>
    <div id="score">Score: 0</div>
    <input type="file" id="audioFile" accept="audio/*">
    <input type="text" id="audioUrl" placeholder="Audio URL (download YT first)">
    <button id="loadBtn">Load and Generate Map</button>
    <button id="startBtn" disabled>Start Game</button>
    <div id="layout">CVNM layout</div>
    <audio id="audio" controls></audio>
    <script src="script.js"></script>
</body>
</html>
